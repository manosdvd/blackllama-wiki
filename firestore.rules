rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==========================================
    // HELPER FUNCTIONS
    // ==========================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isModerator() {
      // Assuming admins assign a custom claim 'moderator'
      return isAuthenticated() && request.auth.token.moderator == true;
    }

    function isAuthor(docData) {
      return isAuthenticated() && request.auth.uid == docData.authorId;
    }

    // ==========================================
    // FORUM TOPICS (Zero-DM Enforced: All public reads)
    // ==========================================
    match /forum_topics/{topicId} {
      // ANY authenticated user can read topics (Public by default)
      allow read: if isAuthenticated();

      // Only authenticated users can create, and they must set themselves as author
      allow create: if isAuthenticated() 
                    && request.resource.data.authorId == request.auth.uid;

      // Authors can update their topics (e.g. edit title), OR moderators can lock them
      allow update: if isAuthor(resource.data) 
                    || (isModerator() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isLocked']));

      // Only moderators can delete topics entirely
      allow delete: if isModerator();
    }

    // ==========================================
    // FORUM POSTS
    // ==========================================
    match /forum_posts/{postId} {
      // ANY authenticated user can read posts (Public by default)
      allow read: if isAuthenticated();

      // Only authenticated users can reply, must be to an unlocked topic
      allow create: if isAuthenticated() 
                    && request.resource.data.authorId == request.auth.uid;

      // Authors can update content, OR anyone can flag a post, OR mods can remove
      allow update: if isAuthor(resource.data) 
                    || (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isFlagged', 'flagCount']))
                    || isModerator();

      // Only moderators can delete posts
      allow delete: if isModerator();
    }

    // ==========================================
    // MODERATION LOGS (Transparency)
    // ==========================================
    match /moderation_logs/{logId} {
      // Only moderators can read or write logs (Two-adult rule enforcement)
      allow read, write: if isModerator();
    }

    // ==========================================
    // WIKI (From previous phase)
    // ==========================================
    match /wiki_articles/{articleId} {
      // All staff can read wiki
      allow read: if isAuthenticated();
      // Assume 'editor' or 'admin' claim for writing
      allow write: if isAuthenticated() && (request.auth.token.admin == true || request.auth.token.editor == true);
    }

    // ==========================================
    // TICKER
    // ==========================================
    match /liveTicker/{itemId} {
      // Ticker feeds are public reading
      allow read: if true;
      // Writes are handled by the server using firebase-admin (which bypasses rules)
      allow write: if false; 
    }
  }
}
