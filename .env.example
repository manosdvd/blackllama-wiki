# ──────────────────────────────────────────────────────────────────────────────
# Camp Lawton Staff Command Center - Environment Configuration Template
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to '.env.local' and populate it with actual keys.
# Do NOT commit '.env.local' to source control.

# 1. Firebase Client Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id

# 2. Firebase Server/Admin Configuration
# Typically a JSON string of the Firebase Admin SDK service account key
FIREBASE_SERVICE_ACCOUNT='{"type": "service_account", ...}'

# 3. Operations & Safety Feeds
# FIRMS API Key (NASA Earthdata Active Fire Detections)
FIRMS_MAP_KEY=your_nasa_firms_api_key

# AirNow API Key (EPA Air Quality Reports)
AIRNOW_API_KEY=your_epa_airnow_api_key

# Optional FirePing/GOES-style satellite fire detection feed.
FIREPING_API_KEY=your_fireping_api_key
FIREPING_API_URL=https://example.com/fireping/detections

# eBird API Key (Cornell recent nearby bird observations)
EBIRD_API_KEY=your_ebird_api_key

# Optional AZGFD HabiMap ArcGIS FeatureServer/MapServer layer URLs.
# Comma-separate multiple layer URLs. Use layer URLs, not the root service URL.
HABIMAP_LAYER_URLS=https://example.maps.arcgis.com/arcgis/rest/services/HabiMap_Layer/FeatureServer/0

# 4. Gemini AI Configuration
GEMINI_API_KEY=your_gemini_api_key
